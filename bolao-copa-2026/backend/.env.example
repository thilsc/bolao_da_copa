# Football Data API Key (football-data.org)
# Obtenha sua chave em: https://www.football-data.org/
FOOTBALL_DATA_API_KEY=sua_chave_aqui

# JWT Secret para autenticação - DEVE TER PELO MENOS 32 CARACTERES
# Gere um segredo forte usando: openssl rand -base64 32
JWT_SECRET=gerar_segredo_forte_aqui_com_pelo_menos_32_caracteres

# URL da aplicação
APP_URL=http://localhost:3001

# Configurações SMTP para envio de emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_aqui

# Porta do servidor
PORT=3001

# Senha do administrador (opcional)
# Se não definida, será usada uma senha padrão (altere em produção!)
ADMIN_PASSWORD=

# Ambiente (development ou production)
NODE_ENV=development
